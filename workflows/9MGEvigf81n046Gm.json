    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst path = require('path');\n\nconst items = $input.all();\n\nif (!items.length) {\n  throw new Error(\"No input received\");\n}\n\n// Lấy biên nhận từ JSON input\nconst receipt = items[0].json.receipt;\n\nif (!receipt) {\n  throw new Error(\"Missing 'receipt' in input\");\n}\n\n// Thư mục chứa ảnh\nconst baseDir = '/data/app_images';\n\n// Thư mục cần xoá: /data/app_images/<receipt>\nconst targetDir = path.join(baseDir, receipt);\n\n// Kiểm tra tồn tại\nif (fs.existsSync(targetDir)) {\n  fs.rmSync(targetDir, { recursive: true, force: true });\n\n  return [{\n    json: {\n      deleted: true,\n      receipt,\n      path: targetDir\n    }\n  }];\n} else {\n  return [{\n    json: {\n      deleted: false,\n      receipt,\n      message: `Folder does not exist`,\n      path: targetDir\n    }\n  }];\n}\n"
      },
