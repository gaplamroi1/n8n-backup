    {
      "parameters": {
        "jsCode": "// Lấy phiên từ node Filter (input khác)\nconst phien = ($items('Filter')[0]?.json?.value || '').toString().trim();\n\n// Lấy toàn bộ dòng từ Extract from File\nconst rows = $items('Extract from File').map(it => it.json);\n\n// Chèn field sau \"Giải trình\" (không phụ thuộc thứ tự cột ban đầu)\nconst out = rows.map(r => {\n  const entries = Object.entries(r);\n  const idx = entries.findIndex(([k]) => k.trim().toLowerCase() === 'giải trình');\n  const insert = ['Phiên kiểm kê', phien];\n\n  if (idx >= 0) {\n    entries.splice(idx + 1, 0, insert);           // chèn ngay sau \"Giải trình\"\n  } else {\n    entries.push(insert);                          // không thấy thì thêm cuối\n  }\n\n  // Dựng object theo thứ tự mới\n  const obj = {};\n  for (const [k, v] of entries) obj[k] = v;\n  return { json: obj };\n});\n\nreturn out;\n"
      },
