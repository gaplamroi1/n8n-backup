    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Lấy đúng dữ liệu ngay SAU node If (nhánh true)\n// -> nếu tên node If của bạn khác, thay \"If\" cho khớp\nconst fromIF = ($items(\"if_new\", 0, $itemIndex)?.json) || {};\n\n// Ưu tiên: keywords -> tags -> (fallback) topic/title\nconst candidates = [\n  fromIF.keywords,   $json.keywords,\n  fromIF.tags,       $json.tags,\n  fromIF.topic,      $json.topic,\n  fromIF.title,      $json.title,\n].filter(v => v && String(v).trim());\n\nlet raw = candidates.join(\" \").toString();\n\n// Làm sạch: bỏ #, phân tách bằng , ; | xuống dòng, chuẩn hoá space\nraw = raw.replace(/#/g, \" \")\n         .replace(/[\\n\\r]+/g, \" \")\n         .replace(/[;,|]+/g, \" \")\n         .replace(/\\s+/g, \" \")\n         .trim();\n\n// Tách từ, loại trùng, bỏ từ quá ngắn, ghép lại thành câu truy vấn\nconst seen = new Set();\nconst terms = raw.split(\" \")\n  .map(s => s.trim())\n  .filter(s => s.length >= 2 && !seen.has(s) && seen.add(s));\n\n// Nếu vẫn rỗng, dùng mặc định an toàn\nconst q = terms.length ? terms.join(\" \") : \"nature abstract\";\n\n// Số ảnh mong muốn (broll_count trong sheet), lấy từ If hoặc JSON hiện tại\nconst want = Number(fromIF.broll_count ?? $json.broll_count ?? 6);\n\n// Lấy dư để lọc dọc, nhưng không quá 50 theo API Pexels\nconst perPage = Math.min(Math.max(want * 3, 15), 50);\n\nreturn {\n  ...$json, // giữ rowNumber, script_text, v.v.\n  _pexels: {\n    q,\n    perPage,\n    page: 1,\n    orientation: \"portrait\",\n    size: \"large\"\n  },\n  // giữ lại truy vết tiện debug\n  _debug_pexels: { want, q_source: candidates }\n};"
      },
