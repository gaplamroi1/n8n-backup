  "name": "schedule-clean-warranty-data",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst path = require('path');\n\nconst baseDir = '/data/app_images';\n\ntry {\n  // Đọc danh sách và lọc folder\n  const dirents = fs.readdirSync(baseDir, { withFileTypes: true });\n  const folders = dirents.filter(d => d.isDirectory()).map(d => d.name);\n\n  const now = Date.now();\n\n  const items = folders.map(name => {\n    const fullPath = path.join(baseDir, name);\n    let stats;\n    try {\n      stats = fs.statSync(fullPath);\n    } catch (err) {\n      // Nếu không thể đọc stats, vẫn trả về minimal info\n      return {\n        json: {\n          folder: name,\n          path: fullPath,\n          createdAt: null,\n          createdAtIso: null,\n          ageDays: null,\n          ageHuman: null,\n          fileCount: null,\n          error: `stat failed: ${err.message}`\n        }\n      };\n    }\n\n    // ưu tiên birthtime, fallback sang ctime hoặc mtime\n    const createdTime = stats.birthtimeMs || stats.ctimeMs || stats.mtimeMs || stats.ino || 0;\n    const createdAtIso = createdTime ? new Date(createdTime).toISOString() : null;\n    const ageMs = createdTime ? (now - createdTime) : null;\n    const ageDays = ageMs != null ? Number((ageMs / (1000 * 60 * 60 * 24)).toFixed(2)) : null;\n\n    // Tạo chuỗi tuổi dễ đọc\n    let ageHuman = null;\n    if (ageMs != null) {\n      const days = Math.floor(ageMs / (1000 * 60 * 60 * 24));\n      const hours = Math.floor((ageMs / (1000 * 60 * 60)) % 24);\n      const minutes = Math.floor((ageMs / (1000 * 60)) % 60);\n      ageHuman = `${days}d ${hours}h ${minutes}m`;\n    }\n\n    // Đếm file (không đệ quy sâu) — nếu muốn đệ quy có thể thay đổi\n    let fileCount = null;\n    try {\n      const inner = fs.readdirSync(fullPath, { withFileTypes: true });\n      fileCount = inner.length;\n    } catch (e) {\n      fileCount = null;\n    }\n\n    return {\n      json: {\n        folder: name,\n        path: fullPath,\n        createdAt: createdTime,\n        createdAtIso,\n        ageDays,\n        ageHuman,\n        fileCount\n      }\n    };\n  });\n\n  // Sắp xếp: mới nhất (creation time lớn) trước. Nếu muốn ngược lại đổi b-a thành a-b\n  items.sort((a, b) => {\n    const ta = a.json.createdAt || 0;\n    const tb = b.json.createdAt || 0;\n    return tb - ta;\n  });\n\n  return items;\n} catch (err) {\n  throw new Error(`Cannot read base directory ${baseDir}: ${err.message}`);\n}\n"
      },
