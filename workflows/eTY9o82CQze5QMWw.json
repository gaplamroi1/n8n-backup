    {
      "parameters": {
        "jsCode": "// Lấy dữ liệu từ bước trước\nconst data = $input.all();\nconst qty = parseInt($('get_sku_and_qty').item.json.qty) || 1;\n\n// Thời gian hiện tại (chỉ lấy ngày, set giờ về 00:00:00)\nconst now = new Date();\nnow.setHours(0, 0, 0, 0);\n\n// Xử lý dữ liệu\nconst processedData = data.map(item => {\n  const json = item.json;\n  \n  // Parse ngày nhập kho\n  let ngayNhapKho = json['Ngày nhập kho'] || json['Ngày_nhập_kho'];\n  \n  if (!ngayNhapKho) {\n    return null;\n  }\n  \n  // Chuyển đổi string thành Date object\n  let nhapKhoDate;\n  if (typeof ngayNhapKho === 'string') {\n    const trimmed = ngayNhapKho.trim();\n    \n    // Kiểm tra format YYYY-MM-DD\n    if (trimmed.match(/^\\d{4}-\\d{1,2}-\\d{1,2}$/)) {\n      const parts = trimmed.split('-');\n      nhapKhoDate = new Date(\n        parseInt(parts[0]), // year\n        parseInt(parts[1]) - 1, // month (0-indexed)\n        parseInt(parts[2]) // day\n      );\n    }\n    // Kiểm tra format DD/MM/YYYY hoặc DD/MM/YYYY HH:mm:ss\n    else if (trimmed.includes('/')) {\n      const parts = trimmed.split(' ')[0].split('/');\n      nhapKhoDate = new Date(\n        parseInt(parts[2]), // year\n        parseInt(parts[1]) - 1, // month (0-indexed)\n        parseInt(parts[0]) // day\n      );\n    }\n    else {\n      return null;\n    }\n  } else {\n    nhapKhoDate = new Date(ngayNhapKho);\n  }\n  \n  // Set giờ về 00:00:00 để chỉ so sánh ngày\n  nhapKhoDate.setHours(0, 0, 0, 0);\n  \n  // Tính diff (milliseconds)\n  const diffMs = now - nhapKhoDate;\n  \n  // Tính diff theo ngày\n  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));\n  \n  return {\n    ...json,\n    diffMs: diffMs,\n    diffDays: diffDays,\n    ngayNhapKhoFormatted: nhapKhoDate.toISOString().split('T')[0],\n    serial: json['Số Serial'] || json['So_Serial'] || json['Loại Serial']\n  };\n}).filter(item => item !== null && !isNaN(item.diffMs));\n\n// Sắp xếp theo diff giảm dần (thời gian lâu nhất)\nprocessedData.sort((a, b) => b.diffMs - a.diffMs);\n\n// Lấy qty + 1 items\nconst topItems = processedData.slice(0, qty + 1);\n\n// Return kết quả\nreturn topItems.map(item => ({\n  json: item\n}));"
      },
