    {
      "parameters": {
        "jsCode": "// Nhận N items (mỗi item là 1 ảnh đã tải).\n// Lấy voice_path & script_text từ các node trước (mỗi workflow chỉ có 1 TTS item).\nconst voiceItem = $items(\"gen_voice\", 0, 0); // đổi tên nếu node TTS của bạn khác\nconst voicePath = voiceItem?.binary?.voice?.filePath || '';\nconst base = items[0].json;\n\n// Danh sách file ảnh (đường dẫn thật trong container)\nconst files = items\n  .map(i => i.binary?.file?.filePath)\n  .filter(Boolean);\n\n// Lập list.txt (ffmpeg concat)\nconst listTxt = files.map(p => `file '${String(p).replace(/'/g, `'\\\\''`)}'`).join('\\n');\n\n// Phân bổ phụ đề đơn giản theo số câu / thời lượng mong muốn\nconst duration = Number(base.duration_sec || 45);\nconst text = (voiceItem?.json?.script_text || base.script_text || '').toString().trim() || ' ';\nconst sentences = text\n  .replace(/\\r/g,' ')\n  .split(/(?<=[\\.\\!\\?])\\s+/)\n  .filter(s => s.trim().length > 0);\n\nconst total = sentences.length || 1;\nconst slice = duration / total;\nconst toTime = (s) => {\n  const ms = Math.round(s*1000);\n  const hh = String(Math.floor(ms/3600000)).padStart(2,'0');\n  const mm = String(Math.floor((ms%3600000)/60000)).padStart(2,'0');\n  const ss = String(Math.floor((ms%60000)/1000)).padStart(2,'0');\n  const m  = String(ms%1000).padStart(3,'0');\n  return `${hh}:${mm}:${ss},${m}`;\n};\nlet t = 0, idx = 1, srt = '';\nfor (const s of sentences) {\n  const start = toTime(t);\n  const end = toTime(t + slice);\n  srt += `${idx}\\n${start} --> ${end}\\n${s.trim()}\\n\\n`;\n  t += slice; idx++;\n}\n\n// Chọn thư mục làm việc trong container\nconst ts = Math.floor(Date.now()/1000);\nconst cwork = `/data/media/work/${ts}`;\nconst workRel = `./media/work/${ts}`; // xem trên host\n\nreturn [{\n  json: {\n    rowNumber: base.rowNumber ?? base._row_number ?? base.row_number,\n    duration_sec: duration,\n    list_txt: listTxt,\n    srt_txt: srt,\n    voice_path: voicePath,\n    cwork,\n    work_rel: workRel,\n    title: base.title || 'clip'\n  }\n}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1920,
        -64
      ],
      "id": "ffca3230-384e-4f39-bc53-dc01bb8bcb04",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "command": "=set -e\n\nCWORK=\"{{$json.cwork}}\"\nmkdir -p \"$CWORK/assets\"\n\n# Ghi list.txt\ncat > \"$CWORK/list.txt\" <<'EOF_LIST'\n{{$json.list_txt}}\nEOF_LIST\n\n# Ghi subtitles.srt\ncat > \"$CWORK/subtitles.srt\" <<'EOF_SRT'\n{{$json.srt_txt}}\nEOF_SRT\n\n# Tạo nền 9:16 từ ảnh\nffmpeg -y -r 1/1 -f concat -safe 0 -i \"$CWORK/list.txt\" \\\n  -vf \"scale=1080:1920:force_original_aspect_ratio=decrease,pad=1080:1920:(ow-iw)/2:(oh-ih)/2\" \\\n  -t {{$json.duration_sec}} -an \"$CWORK/vid_bg.mp4\"\n\n# Ghép phụ đề + audio TTS\nffmpeg -y -i \"$CWORK/vid_bg.mp4\" -i \"{{$json.voice_path}}\" \\\n  -vf \"subtitles='$CWORK/subtitles.srt':force_style=Fontsize=28,Outline=2,Shadow=0,MarginV=40\" \\\n  -c:v libx264 -preset veryfast -crf 22 -r 30 -pix_fmt yuv420p -c:a aac -shortest \"$CWORK/output.mp4\"\n\n# In đường dẫn ra STDOUT\necho \"$CWORK/output.mp4\"\n"
      },
