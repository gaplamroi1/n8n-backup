    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Lấy response hiện tại\nconst resp = $json;\n\n// Script & usage\nconst content = resp.choices?.[0]?.message?.content || '';\nconst promptTokens = Number(resp.usage?.prompt_tokens || 0);\nconst completionTokens = Number(resp.usage?.completion_tokens || 0);\n\n// Đơn giá (USD / 1M tokens) — bạn có thể đổi sau\nconst PRICE_IN = 0.15;   // GPT-4o mini input\nconst PRICE_OUT = 0.60;  // GPT-4o mini output\nconst cost_llm = (promptTokens/1e6)*PRICE_IN + (completionTokens/1e6)*PRICE_OUT;\n\n// Lấy lại row gốc cùng index từ node build_prompt\nconst orig = $items(\"build_prompt\", 0, $itemIndex).json;\n\nreturn {\n  ...orig,\n  script_text: content,\n  tokens_in: promptTokens,\n  tokens_out: completionTokens,\n  cost_llm_usd: Number(cost_llm.toFixed(6)),\n};\n"
      },
