    {
      "parameters": {
        "jsCode": "const want = Number(items[0].json.broll_count || 6);\nconst photos = (items[0].json.photos || []);\n// Ưu tiên ảnh có 'src.portrait' hoặc 'src.large2x'\nconst picks = [];\nconst seen = new Set();\n\nfor (const p of photos) {\n  const url = p.src?.portrait || p.src?.large2x || p.src?.large;\n  if (!url) continue;\n  if (seen.has(url)) continue;\n  seen.add(url);\n  picks.push({\n    json: {\n      ...items[0].json,   // mang theo rowNumber, script_text, tts info...\n      _asset: {\n        url,\n        author: p.photographer,\n        id: p.id\n      }\n    }\n  });\n  if (picks.length >= want) break;\n}\n\n// Nếu không đủ, thôi cứ lấy được bao nhiêu thì lấy\nreturn picks.length ? picks : items.map(i => ({ json: { ...i.json, _warn: 'NO_PEXELS_RESULTS' } }));\n"
      },
