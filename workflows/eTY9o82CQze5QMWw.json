    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Function Item — Run once for each item\n// Input: $json.data.content = \"sku qty\" (ví dụ \"250900201 2\")\n\nconst s = String($json.data?.content ?? $json.content ?? '').trim();\n\nlet sku = '';\nlet qty = NaN;\n\n// Ưu tiên đúng mẫu \"<sku><space><qty>\"\nconst m = s.match(/^\\s*(\\d+)\\s+(-?\\d+)\\s*$/);\nif (m) {\n  sku = m[1];\n  qty = parseInt(m[2], 10);\n} else {\n  // fallback: tách theo khoảng trắng/ký tự phân cách\n  const parts = s.split(/[\\s,;|]+/).filter(Boolean);\n  if (parts.length >= 2) {\n    sku = parts[0].replace(/\\D/g, '');\n    qty = parseInt(parts[1].replace(/[^\\d-]/g, ''), 10);\n  }\n}\n\n// Luôn trả 1 object; nếu lỗi, trả error để node sau tự xử lý\nif (!sku || !Number.isFinite(qty)) {\n  return { json: { error: 'bad_format', raw: s } };\n}\n\nreturn { json: { sku, qty  } };"
      },
