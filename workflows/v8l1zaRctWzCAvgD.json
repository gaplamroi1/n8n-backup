    {
      "parameters": {
        "jsCode": "// Function Item: chạy trên từng item một\nconst row = $json;\n\nconst topic = (row.topic || '').toString().trim();\nconst keywords = (row.keywords || '').toString().trim();\nconst cta = (row.cta || '').toString().trim();\nconst lang = (row.lang || 'vi').toString().trim();\nconst duration = Number(row.duration_sec || 45);\n\nconst systemPrompt = `\nYou are a short-form scriptwriter. Write a concise, high-retention vertical video script in ${lang}.\nTarget duration ~${duration} seconds. Use Vietnamese if lang=vi.\nRules:\n- 1 hook sentence (max 12 words), punchy.\n- 3–6 micro-points, each 1–2 sentences, concrete & actionable.\n- Natural spoken tone, avoid “hàn lâm”.\n- End with CTA: ${cta}.\n- Return text only, no markdown, no numbering.\n`.trim();\n\nconst userPrompt = `\nTopic: ${topic}\nKeywords (for b-roll search): ${keywords}\nLanguage: ${lang}\nTarget duration: ${duration}s\nCTA: ${cta}\n`.trim();\n\nreturn {\n  ...row,\n  _llm: {\n    model: 'gpt-4o-mini',\n    temperature: 0.7,\n    system: systemPrompt,\n    user: userPrompt,\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        368,
        -64
      ],
      "id": "e2de6674-962a-4480-b2af-f48c444bc103",
      "name": "build_prompt"
    },
    {
      "parameters": {
        "jsCode": "// LẤY DỮ LIỆU SAU NODE IF (nhánh true), fallback sang $json hiện tại\nconst fromIF = ($items(\"if_new\", 0, $itemIndex)?.json) || {};\nconst script = ($json.script_text || '').toString().trim();\n\n// Trường trên sheet\nconst voiceFromSheet  = (fromIF.voice || $json.voice || '').toString().trim();              // alloy / verse ...\nconst modelFromSheet  = (fromIF.voice_model || $json.voice_model || $json.tts_model || '')\n  .toString().trim();  // tts-1 / tts-1-hd (cột bạn đặt là voice_model)\n\n// Chuẩn hoá: nếu người dùng lỡ gõ 'tts-1-hd' vào cột voice, tự chỉnh lại\nconst MODEL_SET = new Set(['tts-1','tts-1-hd']);\nlet ttsModel = modelFromSheet || (MODEL_SET.has(voiceFromSheet) ? voiceFromSheet : 'tts-1');\nlet voice    = MODEL_SET.has(voiceFromSheet) ? 'alloy' : (voiceFromSheet || 'alloy');\n\n// Định dạng file xuất\nconst format = 'mp3';\n\n// Đếm ký tự & tính chi phí TTS\nconst chars = script.length;\nconst PRICE = { 'tts-1': 15, 'tts-1-hd': 30 }; // USD / 1M chars\nconst costTTS = (chars / 1e6) * (PRICE[ttsModel] ?? PRICE['tts-1']);\n\nreturn {\n  ...$json,                    // giữ rowNumber, tokens, cost_llm_usd, script_text...\n  _tts: { model: ttsModel, voice, format },\n  tts_chars: chars,\n  cost_tts_usd: Number(costTTS.toFixed(6)),\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
