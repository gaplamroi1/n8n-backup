    {
      "parameters": {
        "jsCode": "// Function — Run once for all items\n// Lấy: 1) \"phiên kiểm kê\" từ header dạng KK-xxxx-xxxx\n//      2) \"Ngày yêu cầu kiểm kê\"\n//      3) \"khu vực kiểm kê\"\n\nconst rows = $input.all().map(it => it.json);\nconst table = rows.map(r => Object.values(r).map(v => String(v ?? '').trim()));\n\nconst norm = s => String(s ?? '')\n  .normalize('NFD').replace(/[\\u0300-\\u036f]/g,'')\n  .toLowerCase().trim();\nconst raw = s => String(s ?? '').trim();\n\n// ===== 1) PHIÊN kiểm kê từ header (KK-xxxx-xxxx) =====\nlet phien = '';\nif (table.length) {\n  const upTo = Math.min(50, table.length);\n  const lines = [];\n  for (let i = 0; i < upTo; i++) lines.push(raw(table[i].join(' ')));\n  const headerText = lines.join('  ');\n\n  let m = headerText.match(/\\bkk[^0-9]*?(\\d{4})[^0-9]*?(\\d{4})\\b/i);\n  if (m) phien = `KK-${m[1]}-${m[2]}`;\n  if (!phien) {\n    const m2 = headerText.replace(/\\s+/g,'').match(/\\bkk(\\d{8})\\b/i);\n    if (m2) phien = `KK-${m2[1].slice(0,4)}-${m2[1].slice(4)}`;\n  }\n  if (!phien) {\n    outer:\n    for (let i = 0; i < upTo; i++) {\n      const row = table[i];\n      for (let j = 0; j < row.length; j++) {\n        const cell = row[j];\n        if (!/kk/i.test(cell)) continue;\n        let digits = (cell.match(/(\\d+)/g) || []).join('');\n        for (let k = j + 1; k < row.length && digits.length < 8; k++) {\n          const tok = row[k];\n          const nums = tok.match(/^\\D*(\\d+)/);\n          if (!nums) break;\n          digits += nums[1];\n        }\n        if (digits.length < 8 && i + 1 < table.length) {\n          for (let k = 0; k < table[i+1].length && digits.length < 8; k++) {\n            const tok = table[i+1][k];\n            const nums = tok.match(/^\\D*(\\d+)/);\n            if (!nums) continue;\n            digits += nums[1];\n          }\n        }\n        if (digits.length >= 8) {\n          digits = digits.slice(0,8);\n          phien = `KK-${digits.slice(0,4)}-${digits.slice(4)}`;\n          break outer;\n        }\n      }\n    }\n  }\n  if (!phien) {\n    const compact = headerText.replace(/[^A-Za-z0-9]+/g,'').toLowerCase();\n    const m3 = compact.match(/kk(\\d{8})/i);\n    if (m3) phien = `KK-${m3[1].slice(0,4)}-${m3[1].slice(4)}`;\n  }\n}\n\n// ===== 2) \"Ngày yêu cầu kiểm kê\" + 3) \"khu vực kiểm kê\" =====\nconst tokens = {\n  // đổi sang \"ngày yêu cầu kiểm kê\" thay vì \"ngày hoàn thành\"\n  ngayYC: [\n    'ngay yeu cau kiem ke',\n    'ngay yeu cau',\n    'ngay yc kiem ke',\n    'requested date',\n    'request date',\n    'date requested'\n  ],\n  khu: [\n    'khu vuc kiem ke',\n    'khu vuc',\n    'khu vuc kk',\n    'area'\n  ],\n};\nconst hasToken = (s, list) => list.some(t => norm(s).includes(t));\nconst pickAfterSep = s => {\n  const mm = String(s).match(/[:\\-–]\\s*(.+)$/);\n  return mm ? raw(mm[1]) : '';\n};\nconst rightCell = (vals, j) => {\n  for (let k = j + 1; k < vals.length; k++) { const v = raw(vals[k]); if (v) return v; }\n  return '';\n};\nconst nextRowFirst = (tbl, i) => {\n  if (i + 1 >= tbl.length) return '';\n  const vals = tbl[i + 1];\n  for (let k = 0; k < vals.length; k++) { const v = raw(vals[k]); if (v) return v; }\n  return '';\n};\n\nlet ngayYC = '';\nlet khu = '';\n\n// theo tiêu đề cột\nif (table.length) {\n  const header = table[0].map(raw);\n  const idxBy = lists => {\n    for (let j = 0; j < header.length; j++) if (hasToken(header[j], lists)) return j;\n    return -1;\n  };\n  const colNgayYC = idxBy(tokens.ngayYC);\n  const colKhu    = idxBy(tokens.khu);\n\n  const firstBelow = col => {\n    if (col < 0) return '';\n    for (let i = 1; i < table.length; i++) {\n      const v = raw(table[i][col]); if (v) return v;\n    }\n    return '';\n  };\n  if (!ngayYC) ngayYC = firstBelow(colNgayYC);\n  if (!khu)    khu    = firstBelow(colKhu);\n}\n\n// quét nhãn:giá trị\nif (!ngayYC || !khu) {\n  outer2:\n  for (let i = 0; i < table.length; i++) {\n    const row = table[i];\n    for (let j = 0; j < row.length; j++) {\n      const cell = raw(row[j]);\n      if (!cell) continue;\n      if (!ngayYC && hasToken(cell, tokens.ngayYC)) {\n        ngayYC = pickAfterSep(cell) || rightCell(row, j) || nextRowFirst(table, i);\n      }\n      if (!khu && hasToken(cell, tokens.khu)) {\n        khu = pickAfterSep(cell) || rightCell(row, j) || nextRowFirst(table, i);\n      }\n      if (ngayYC && khu) break outer2;\n    }\n  }\n}\n\n// ===== Output 3 item =====\nreturn [\n  { json: { key: 'ngày yêu cầu kiểm kê', value: ngayYC || '' } },\n  { json: { key: 'phiên kiểm kê', value: phien || '' } },\n  { json: { key: 'khu vực kiểm kê', value: khu || '' } },\n];"
      },
